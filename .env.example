AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=DEIN_ACCOUNT;AccountKey=DEIN_KEY;EndpointSuffix=core.windows.net
ANTHROPIC_API_KEY=sk-ant-...

# Haushaltskasse — Azure Database for PostgreSQL (Flexible Server)
# Passwort NIEMALS ins Repo — nur hier lokal in der echten .env eintragen.
HAUSHALT_DATABASE_URL=postgresql://adminuser:DEIN_PASSWORT@DEIN_SERVER.postgres.database.azure.com:5432/haushaltskasse?sslmode=require

# Dashboard-Login (P0.1) — Hash + Secret erzeugen mit: python -m haushaltskasse.dashboard.auth
HAUSHALT_APP_USER=DEIN_NAME
HAUSHALT_APP_PASSWORD_HASH=$2b$12$...bcrypt-hash...
HAUSHALT_SESSION_SECRET=langer_zufallswert_hex
HAUSHALT_HTTPS_ONLY=1
